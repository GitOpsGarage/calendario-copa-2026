{
  "name": "app-copa",
  "build": { "dockerfile": "Dockerfile" },
  
  "remoteEnv": {
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "OBSIDIAN_API_KEY": "${localEnv:OBSIDIAN_API_KEY}",
    "AI_MEMORY_API_KEY": "${localEnv:AI_MEMORY_API_KEY}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  },
  "features": {"ghcr.io/devcontainers/features/node:1": {"version": "20"}},
  "postCreateCommand": "bash /workspace/.devcontainer/onboarding.sh",
  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,readonly",
    "source=${localEnv:HOME}/.config/gh,target=/home/vscode/.config/gh,type=bind,readonly"
  ],
  "forwardPorts": [],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "workspaceFolder": "/workspace",
  "runArgs": ["--network=host"]
}
